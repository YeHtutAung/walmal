# ─────────────────────────────────────────────────────────────────
# Walmal Backend — Required Environment Variables
#
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to source control.
#
# Spring Boot property relaxed-binding:
#   SPRING_DATASOURCE_URL → spring.datasource.url
#   SPRING_DATA_REDIS_HOST → spring.data.redis.host
#   etc.
# ─────────────────────────────────────────────────────────────────

# ── Active Spring profile ──────────────────────────────────────
# Options: dev | staging | prod
SPRING_PROFILES_ACTIVE=dev

# ── Database (PostgreSQL) ──────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/walmal
SPRING_DATASOURCE_USERNAME=walmal
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# ── Cache (Redis) ─────────────────────────────────────────────
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
# Leave blank for Redis instances without authentication (e.g. local dev)
SPRING_DATA_REDIS_PASSWORD=

# ── Message Broker (RabbitMQ) ─────────────────────────────────
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=walmal
SPRING_RABBITMQ_PASSWORD=CHANGE_ME
SPRING_RABBITMQ_VIRTUAL_HOST=/

# ── Object Storage (MinIO / S3-compatible) ────────────────────
MINIO_URL=http://localhost:9000
# Public URL used in pre-signed URLs returned to clients
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
WALMAL_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
WALMAL_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Trust X-Forwarded-For from a reverse proxy (Nginx/Caddy)
WALMAL_TRUST_PROXY=false

# ── Email (SMTP) ──────────────────────────────────────────────
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=noreply@example.com
SPRING_MAIL_PASSWORD=CHANGE_ME

# ── Rate Limiting ─────────────────────────────────────────────
# Requests per minute per IP
WALMAL_RATE_LIMIT_AUTHENTICATED=60
WALMAL_RATE_LIMIT_UNAUTHENTICATED=20

# ── Stripe (processed frontend-side; backend validates webhooks) ─
# Not required unless you add webhook signature validation to the backend.
# STRIPE_API_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Spring Boot Actuator ──────────────────────────────────────
# The /actuator/prometheus endpoint is protected by ADMIN role.
# No additional env var needed — configure in SecurityConfig.

# ─────────────────────────────────────────────────────────────────
# Quick-start for local dev (matches docker-compose.yml defaults)
# ─────────────────────────────────────────────────────────────────
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/walmal
# SPRING_DATASOURCE_USERNAME=walmal
# SPRING_DATASOURCE_PASSWORD=walmal
# SPRING_DATA_REDIS_HOST=localhost
# SPRING_RABBITMQ_HOST=localhost
# SPRING_RABBITMQ_USERNAME=walmal
# SPRING_RABBITMQ_PASSWORD=walmal
# MINIO_URL=http://localhost:9000
# MINIO_ACCESS_KEY=walmal
# MINIO_SECRET_KEY=walmal123
# WALMAL_JWT_SECRET=walmal-dev-secret-key-change-in-production-minimum-256-bits
