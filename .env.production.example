# ─────────────────────────────────────────────────────────────────
# .env.production.example — Production compose stack env template
#
# Copy to `.env` on the VPS next to docker-compose.prod.yml and fill in
# real values. NEVER commit the real `.env` to source control.
#
#   cp .env.production.example .env
#   docker compose -f docker-compose.prod.yml --env-file .env up -d
#
# Every variable below is referenced by docker-compose.prod.yml or
# deploy/Caddyfile. Names + comments only — no real values live here.
# ─────────────────────────────────────────────────────────────────

# ── Domain (Caddy) ─────────────────────────────────────────────
# Bare apex domain, no scheme, no subdomain — Caddy builds
# shop./admin./api./status./mail.{$WALMAL_DOMAIN} from this.
WALMAL_DOMAIN=

# Email address for Let's Encrypt ACME registration + expiry notices.
ACME_EMAIL=

# ── Database (PostgreSQL) ──────────────────────────────────────
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# ── Cache (Redis) ────────────────────────────────────────────────
# Leave blank only if you have re-configured Redis without auth —
# not recommended on a public VPS.
SPRING_DATA_REDIS_PASSWORD=

# ── Message Broker (RabbitMQ) ────────────────────────────────────
SPRING_RABBITMQ_USERNAME=
SPRING_RABBITMQ_PASSWORD=

# ── Object Storage (MinIO) ───────────────────────────────────────
# MinIO is never exposed publicly — the storefront's /api/minio proxy
# is the only path browsers use to reach it, so MINIO_PUBLIC_URL should
# stay the internal service address.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PUBLIC_URL=http://minio:9000

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
WALMAL_JWT_SECRET=

# ── Home content preview token ───────────────────────────────────
# Gates draft-content preview reads (GET /api/v1/content/home/draft
# ?previewToken=...) for editors/reviewers who are not logged in. Anyone
# holding this value can read unpublished home-page copy, so it MUST be a
# strong random secret — never the dev default. Required in prod (compose
# fails to start without it). Generate with: openssl rand -hex 32
CONTENT_PREVIEW_TOKEN=

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list — the storefront + admin origins, e.g.
# https://shop.example.com,https://admin.example.com
WALMAL_CORS_ALLOWED_ORIGINS=

# Caddy sets X-Forwarded-For, so the backend must trust it to rate-limit
# by real client IP rather than by Caddy's own address. Defaults to true
# in docker-compose.prod.yml.
# WALMAL_TRUST_PROXY=true

# ── Stripe (TEST mode — public demo store, never live mode) ─────
# sk_test_... — used by BOTH the backend (webhook + server-side
# PaymentIntent verification) and the storefront (creates the intent).
# Same key, one source of truth.
STRIPE_SECRET_KEY=
# whsec_... from the Stripe TEST-dashboard webhook pointed at
# https://api.{$WALMAL_DOMAIN}/api/v1/payment/webhook (see docs/DEPLOYMENT.md)
STRIPE_WEBHOOK_SECRET=

# ── Email (MailHog demo sink) ────────────────────────────────────
# Defaults in docker-compose.prod.yml already point at the mailhog
# service (host mailhog, port 1025, no auth/STARTTLS) — uncomment only to
# swap in a real SMTP provider.
# SPRING_MAIL_HOST=mailhog
# SPRING_MAIL_PORT=1025
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=
# SPRING_MAIL_SMTP_AUTH=false
# SPRING_MAIL_SMTP_STARTTLS_ENABLE=false

# ── Rate Limiting ─────────────────────────────────────────────
# Requests per minute per IP (backend). Defaults: 60 authenticated,
# 20 unauthenticated.
# WALMAL_RATE_LIMIT_AUTHENTICATED=60
# WALMAL_RATE_LIMIT_UNAUTHENTICATED=20

# ── MailHog UI basic-auth (Caddy) ────────────────────────────────
# A single "username hash" line (bcrypt), generated with:
#   docker run --rm caddy caddy hash-password --plaintext '<your-password>'
# then set this to: <username> <bcrypt-hash-output>
# See docs/DEPLOYMENT.md for the exact command and an end-to-end example.
MAILHOG_BASIC_AUTH=

# ── Image overrides (optional) ───────────────────────────────────
# All three default to :latest from GHCR; override to pin a specific
# sha-* tag for a rollback.
# WALMAL_IMAGE=ghcr.io/yehtutaung/walmal/walmal-app:latest
# WALMAL_STORE_IMAGE=ghcr.io/yehtutaung/walmal-store:latest
# WALMAL_ADMIN_IMAGE=ghcr.io/yehtutaung/walmal-admin:latest

# ─────────────────────────────────────────────────────────────────
# NOT env vars here (baked into images at CI build time — see the
# repos' GHCR build-and-push jobs, configured via GitHub *variables*):
#   NEXT_PUBLIC_API_URL, NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (walmal-store)
#   VITE_API_BASE_URL (walmal-admin)
# WALMAL_PAYMENT_GATEWAY is hardcoded to `stripe` directly in
# docker-compose.prod.yml (this stack always runs the real gateway in
# Stripe TEST mode) — no env var needed for it.
# ─────────────────────────────────────────────────────────────────
