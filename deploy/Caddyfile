# ─────────────────────────────────────────────────────────────────
# deploy/Caddyfile — production reverse proxy + automatic TLS
#
# Mounted read-only into the `caddy` service (see docker-compose.prod.yml)
# at /etc/caddy/Caddyfile. {$WALMAL_DOMAIN} and {$MAILHOG_BASIC_AUTH} are
# read from the caddy container's environment (populated from the host
# .env — see .env.production.example).
#
# Five subdomains, one IP, one Caddyfile:
#   shop.{$WALMAL_DOMAIN}   -> storefront (Next.js)
#   admin.{$WALMAL_DOMAIN}  -> admin SPA (nginx, its own JWT login — no
#                               extra proxy auth needed, enforcement is
#                               real on the backend)
#   api.{$WALMAL_DOMAIN}    -> Spring Boot backend
#   status.{$WALMAL_DOMAIN} -> Uptime Kuma status page
#   mail.{$WALMAL_DOMAIN}   -> MailHog UI, Caddy basic-auth gated (demo
#                               feature — "see the emails the shop sends";
#                               test mode means no real customer email)
#   {$WALMAL_DOMAIN}        -> redirects to shop.{$WALMAL_DOMAIN}
#
# Caddy auto-provisions Let's Encrypt certs for each site block above
# because they look like real domain names. For a fully local boot with
# no public DNS (Task 8 of the production-deployment plan), uncomment
# the "local dev" global block below instead — see the comment there.
# ─────────────────────────────────────────────────────────────────

# ── Local/dev boot only (uncomment for a local run, e.g. Task 8) ───
# Switches every site block below from ACME/Let's Encrypt to Caddy's
# internal CA, so TLS works against fake hostnames that have no public
# DNS record (e.g. shop.walmal.local resolved via /etc/hosts entries
# pointing at 127.0.0.1). Browsers must trust Caddy's internal root CA
# (or the local proof runs with ignoreHTTPSErrors) to avoid cert warnings.
# {
#     local_certs
# }

{$WALMAL_DOMAIN} {
	redir https://shop.{$WALMAL_DOMAIN}{uri} permanent
}

shop.{$WALMAL_DOMAIN} {
	reverse_proxy store:3000
}

admin.{$WALMAL_DOMAIN} {
	reverse_proxy admin:80
}

api.{$WALMAL_DOMAIN} {
	reverse_proxy app:8080
}

status.{$WALMAL_DOMAIN} {
	reverse_proxy uptime-kuma:3001
}

mail.{$WALMAL_DOMAIN} {
	# {$MAILHOG_BASIC_AUTH} holds a single "username hash" line generated by
	# `caddy hash-password` (bcrypt) — see docs/DEPLOYMENT.md for the exact
	# command. Never put a plaintext password here.
	basic_auth {
		{$MAILHOG_BASIC_AUTH}
	}
	reverse_proxy mailhog:8025
}
